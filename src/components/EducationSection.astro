---
import { education } from "../data/education";
import { GraduationCap, MapPin, Calendar, Award } from "@lucide/astro";
---

<section id="education" class="w-full py-20">
    <!-- Section Header -->
    <div class="flex items-center gap-4 mb-12">
        <div class="p-3 rounded-xl bg-secondary/10 border border-secondary/20">
            <GraduationCap class="w-6 h-6 text-secondary" />
        </div>
        <div>
            <h2 class="text-3xl font-bold text-text-primary">Education</h2>
            <p class="text-text-secondary mt-1">Academic background</p>
        </div>
    </div>

    <!-- Education Cards -->
    <div class="space-y-6">
        {education.map((edu) => (
            <div class="group p-6 rounded-2xl glass-card transition-all duration-300 shadow-lg shadow-secondary/5">
                <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4">
                    <div class="flex-1">
                        <h3 class="text-xl font-semibold text-text-primary">
                            {edu.degree}
                        </h3>
                        <p class="text-lg font-medium text-secondary mt-1">{edu.institution}</p>
                    </div>
                    <div class="flex flex-col gap-2 text-sm text-text-secondary">
                        <div class="flex items-center gap-2">
                            <Calendar class="w-4 h-4 text-text-muted" />
                            <span>{edu.startDate} - {edu.endDate}</span>
                        </div>
                        <div class="flex items-center gap-2">
                            <MapPin class="w-4 h-4 text-text-muted" />
                            <span>{edu.location}</span>
                        </div>
                    </div>
                </div>

                <!-- Highlights -->
                {edu.highlights.length > 0 && (
                    <div class="mt-4 pt-4 border-t border-border">
                        <div class="flex items-center gap-2 mb-3">
                            <Award class="w-4 h-4 text-accent" />
                            <span class="text-sm font-medium text-text-secondary">Achievements</span>
                        </div>
                        <ul class="space-y-2">
                            {edu.highlights.map((highlight: string) => (
                                <li class="flex items-start gap-3 text-text-secondary">
                                    <span class="mt-2 w-1.5 h-1.5 rounded-full bg-secondary/60 flex-shrink-0"></span>
                                    <span class="leading-relaxed">{highlight}</span>
                                </li>
                            ))}
                        </ul>
                    </div>
                )}
            </div>
        ))}
    </div>
</section>
