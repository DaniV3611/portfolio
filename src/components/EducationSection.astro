---
import { education } from "../data/education";
---

<section id="education" class="w-full md:w-3xl lg:w-4xl pt-20">
    <h2 class="text-2xl font-bold text-jet/80 mb-6">Education</h2>
    <div class="flex flex-col gap-4">
        {education.map((edu) => (
            <div class="flex flex-col gap-3 p-6 rounded-lg border border-jet/10 hover:border-munsell/30 hover:shadow-lg transition-all duration-300 bg-ivory/50">
                <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-2">
                    <div class="flex-1">
                        <h3 class="text-lg font-semibold text-jet">{edu.degree}</h3>
                        <p class="text-md font-bold text-munsell">{edu.institution}</p>
                    </div>
                    <div class="text-sm text-jet/60 md:text-right">
                        <p>{edu.startDate} - {edu.endDate}</p>
                        <p class="text-xs">{edu.location}</p>
                    </div>
                </div>
                <ul class="list-disc list-inside space-y-1 text-sm text-jet/80">
                    {edu.highlights.map((highlight: string) => (
                        <li class="leading-relaxed">{highlight}</li>
                    ))}
                </ul>
            </div>
        ))}
    </div>
</section>
