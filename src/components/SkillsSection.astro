---
import { skills } from "../data/skills";
import { Wrench, Code, Server, Database, Cloud, Brain, Monitor } from "@lucide/astro";

const aiData    = skills.find(s => s.category === "AI & Data")!;
const languages = skills.find(s => s.category === "Languages")!;
const frontend  = skills.find(s => s.category === "Frontend")!;
const backend   = skills.find(s => s.category === "Backend")!;
const cloud     = skills.find(s => s.category === "Cloud & DevOps")!;
const databases = skills.find(s => s.category === "Databases")!;
---

<section id="skills" class="w-full py-20">
    <!-- Section Header -->
    <div class="flex items-center gap-4 mb-12">
        <div class="p-3 rounded-xl bg-accent/10 border border-accent/20">
            <Wrench class="w-6 h-6 text-accent" />
        </div>
        <div>
            <h2 class="text-3xl font-bold text-text-primary">Technical Skills</h2>
            <p class="text-text-secondary mt-1">Technologies I work with</p>
        </div>
    </div>

    <div class="space-y-4">

        <!-- Row 1: AI & Data (featured 2/3) + Languages (1/3) -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

            <!-- AI & Data — gradient border, featured -->
            <div class="md:col-span-2 p-[1px] rounded-2xl bg-gradient-to-br from-accent/50 via-accent/15 to-secondary/30">
                <div class="relative p-6 rounded-2xl bg-surface-elevated bg-grid overflow-hidden h-full">
                    <!-- Ambient glow blob -->
                    <div class="absolute -top-10 -right-10 w-52 h-52 bg-accent/10 rounded-full blur-3xl pointer-events-none"></div>

                    <div class="relative">
                        <div class="flex items-center gap-3 mb-5">
                            <div class="p-2 rounded-lg bg-accent/15 border border-accent/25">
                                <Brain class="w-5 h-5 text-accent" />
                            </div>
                            <h3 class="font-semibold text-text-primary text-lg">{aiData.category}</h3>
                            <span class="ml-auto inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-accent/10 border border-accent/25 text-accent text-xs font-medium">
                                ★ Core Expertise
                            </span>
                        </div>
                        <div class="flex flex-wrap gap-2">
                            {aiData.skills.map((skill: string) => (
                                <span class="px-3 py-1.5 text-sm bg-accent/10 border border-accent/20 rounded-lg text-accent/90 hover:bg-accent/20 hover:border-accent/50 hover:text-accent transition-all duration-200 cursor-default font-medium">
                                    {skill}
                                </span>
                            ))}
                        </div>
                    </div>
                </div>
            </div>

            <!-- Languages — monospace aesthetic -->
            <div class="group p-5 rounded-2xl glass-card hover:shadow-lg hover:shadow-accent/5 transition-all duration-300">
                <div class="flex items-center gap-3 mb-4">
                    <div class="p-2 rounded-lg bg-accent/10 border border-accent/20">
                        <Code class="w-4 h-4 text-accent" />
                    </div>
                    <h3 class="font-semibold text-text-primary">{languages.category}</h3>
                </div>
                <div class="flex flex-wrap gap-2">
                    {languages.skills.map((skill: string) => (
                        <span class="px-2.5 py-1 text-xs font-mono bg-surface-elevated border border-border rounded-lg text-text-secondary hover:text-accent hover:border-accent/50 hover:bg-accent/5 transition-all duration-200 cursor-default">
                            {skill}
                        </span>
                    ))}
                </div>
            </div>
        </div>

        <!-- Row 2: Frontend + Backend + Cloud & DevOps -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">

            <!-- Frontend — secondary/amber -->
            <div class="group p-5 rounded-2xl glass-card hover:shadow-lg hover:shadow-secondary/5 transition-all duration-300">
                <div class="flex items-center gap-3 mb-4">
                    <div class="p-2 rounded-lg bg-secondary/10 border border-secondary/20">
                        <Monitor class="w-4 h-4 text-secondary" />
                    </div>
                    <h3 class="font-semibold text-text-primary">{frontend.category}</h3>
                </div>
                <div class="flex flex-wrap gap-2">
                    {frontend.skills.map((skill: string) => (
                        <span class="px-2.5 py-1.5 text-sm bg-surface-elevated border border-border rounded-lg text-text-secondary hover:text-secondary hover:border-secondary/50 hover:bg-secondary/5 transition-all duration-200 cursor-default">
                            {skill}
                        </span>
                    ))}
                </div>
            </div>

            <!-- Backend — success/green -->
            <div class="group p-5 rounded-2xl glass-card hover:shadow-lg hover:shadow-success/5 transition-all duration-300">
                <div class="flex items-center gap-3 mb-4">
                    <div class="p-2 rounded-lg bg-success/10 border border-success/20">
                        <Server class="w-4 h-4 text-success" />
                    </div>
                    <h3 class="font-semibold text-text-primary">{backend.category}</h3>
                </div>
                <div class="flex flex-wrap gap-2">
                    {backend.skills.map((skill: string) => (
                        <span class="px-2.5 py-1.5 text-sm bg-surface-elevated border border-border rounded-lg text-text-secondary hover:text-success hover:border-success/50 hover:bg-success/5 transition-all duration-200 cursor-default">
                            {skill}
                        </span>
                    ))}
                </div>
            </div>

            <!-- Cloud & DevOps — accent/blue -->
            <div class="group p-5 rounded-2xl glass-card hover:shadow-lg hover:shadow-accent/5 transition-all duration-300">
                <div class="flex items-center gap-3 mb-4">
                    <div class="p-2 rounded-lg bg-accent/10 border border-accent/20">
                        <Cloud class="w-4 h-4 text-accent" />
                    </div>
                    <h3 class="font-semibold text-text-primary">{cloud.category}</h3>
                </div>
                <div class="flex flex-wrap gap-2">
                    {cloud.skills.map((skill: string) => (
                        <span class="px-2.5 py-1.5 text-sm bg-surface-elevated border border-border rounded-lg text-text-secondary hover:text-accent hover:border-accent/50 hover:bg-accent/5 transition-all duration-200 cursor-default">
                            {skill}
                        </span>
                    ))}
                </div>
            </div>
        </div>

        <!-- Row 3: Databases — full width horizontal band -->
        <div class="p-5 rounded-2xl glass-card hover:shadow-lg hover:shadow-violet-500/5 transition-all duration-300 group">
            <div class="flex flex-wrap items-center gap-x-6 gap-y-4">
                <div class="flex items-center gap-3 flex-shrink-0">
                    <div class="p-2 rounded-lg bg-violet-500/10 border border-violet-500/20">
                        <Database class="w-4 h-4 text-violet-400" />
                    </div>
                    <h3 class="font-semibold text-text-primary">{databases.category}</h3>
                </div>
                <div class="hidden md:block w-px h-5 bg-border flex-shrink-0"></div>
                <div class="flex flex-wrap gap-2 flex-1">
                    {databases.skills.map((skill: string) => (
                        <span class="px-2.5 py-1.5 text-sm bg-surface-elevated border border-border rounded-lg text-text-secondary hover:text-violet-400 hover:border-violet-500/50 hover:bg-violet-500/5 transition-all duration-200 cursor-default">
                            {skill}
                        </span>
                    ))}
                </div>
            </div>
        </div>

    </div>
</section>
