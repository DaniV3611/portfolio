---
import { ArrowDown, Mail } from "@lucide/astro";
import TechCarousel from "./TechCarousel.tsx";
---

<section id="home" class="flex flex-col justify-center w-full min-h-dvh py-20">
    <!-- Main heading -->
    <div class="space-y-4 mb-8">
        <p
            class="text-text-secondary text-lg animate-fade-in-down animate-delay-100"
        >
            Hello, I'm
        </p>
        <h1
            class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight animate-fade-in-right animate-delay-200"
        >
            <span class="gradient-text">Daniel Velasco</span>
        </h1>
        <h2
            class="text-2xl md:text-3xl lg:text-4xl font-semibold text-text-secondary animate-fade-in-right animate-delay-300"
        >
            AI Systems & Full-Stack Developer
        </h2>
    </div>

    <!-- Description -->
    <p
        class="text-lg text-text-secondary leading-relaxed max-w-2xl mb-10 animate-fade-in-up animate-delay-400"
    >
        I build <span class="text-text-primary font-medium">AI agents</span>,
        and
        <span class="text-text-primary font-medium">SaaS platforms</span> — from architecture
        design to <span class="text-accent">production deployment</span>.
        Specialized in <span class="text-accent">FastAPI</span>,
        <span class="text-secondary">LangGraph</span>, and
        <span class="text-accent">React</span>.
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-wrap gap-4 animate-fade-in-up animate-delay-500">
        <a
            href="mailto:dvelascogz@gmail.com"
            class="group inline-flex items-center gap-2 px-6 py-2 bg-gradient-to-r from-accent to-accent-muted hover:from-accent-hover hover:to-accent-muted text-white font-medium rounded-lg transition-all duration-300 glow-accent-hover"
        >
            <Mail size={16} />
            Get in touch
        </a>
        <a
            href="/#projects"
            class="inline-flex items-center gap-2 px-6 py-2 bg-surface hover:bg-surface-elevated border border-border hover:border-border-hover text-text-primary font-medium rounded-lg transition-all duration-300"
        >
            View my work
            <ArrowDown size={16} class="animate-bounce" />
        </a>
    </div>

    <!-- Tech stack preview -->
    <div class="mt-16 animate-fade-in-up animate-delay-700">
        <p class="text-text-muted text-sm mb-4 uppercase tracking-wider">
            Tech I work with
        </p>
        <TechCarousel client:load />
    </div>
</section>
