---
import { MapPin, Calendar } from "@lucide/astro";

interface Props {
    experience: {
        company: string;
        position: string;
        startDate: string;
        endDate: string;
        location: string;
        responsibilities: string[];
    };
    index: number;
}

const { experience, index } = Astro.props;
const isPresent = experience.endDate === "Present";
---

<div class="relative pl-8 md:pl-20 group">
    <!-- Timeline dot -->
    <div class="absolute left-0 md:left-8 top-6 -translate-x-1/2">
        <div class={`w-4 h-4 rounded-full border-2 transition-all duration-300 ${
            isPresent 
                ? "bg-accent border-accent shadow-lg shadow-accent/50" 
                : "bg-surface border-border group-hover:border-accent group-hover:bg-accent/20"
        }`}>
            {isPresent && (
                <div class="absolute inset-0 rounded-full bg-accent animate-ping opacity-20"></div>
            )}
        </div>
    </div>

    <!-- Card -->
    <div class="p-6 rounded-2xl bg-surface border border-border hover:border-border-hover transition-all duration-300 group-hover:shadow-lg group-hover:shadow-accent/5">
        <!-- Header -->
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-4">
            <div class="flex-1">
                <h3 class="text-xl font-semibold text-text-primary group-hover:text-accent transition-colors duration-300">
                    {experience.position}
                </h3>
                <p class="text-lg font-medium gradient-text mt-1">{experience.company}</p>
            </div>
            <div class="flex flex-col gap-2 text-sm text-text-secondary">
                <div class="flex items-center gap-2">
                    <Calendar class="w-4 h-4 text-text-muted" />
                    <span>{experience.startDate} - {experience.endDate}</span>
                    {isPresent && (
                        <span class="px-2 py-0.5 text-xs font-medium bg-success/10 text-success rounded-full">
                            Current
                        </span>
                    )}
                </div>
                <div class="flex items-center gap-2">
                    <MapPin class="w-4 h-4 text-text-muted" />
                    <span>{experience.location}</span>
                </div>
            </div>
        </div>

        <!-- Responsibilities -->
        <ul class="space-y-2 mt-4">
            {experience.responsibilities.map((responsibility: string) => (
                <li class="flex items-start gap-3 text-text-secondary">
                    <span class="mt-2 w-1.5 h-1.5 rounded-full bg-accent/60 flex-shrink-0"></span>
                    <span class="leading-relaxed">{responsibility}</span>
                </li>
            ))}
        </ul>
    </div>
</div>
