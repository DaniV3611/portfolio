---
const { experience } = Astro.props;
---

<div class="flex flex-col gap-3 p-6 rounded-lg border border-jet/10 hover:border-munsell/30 hover:shadow-lg transition-all duration-300 bg-ivory/50">
    <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-2">
        <div class="flex-1">
            <h3 class="text-lg font-semibold text-jet">{experience.position}</h3>
            <p class="text-md font-bold text-munsell">{experience.company}</p>
        </div>
        <div class="text-sm text-jet/60 md:text-right">
            <p>{experience.startDate} - {experience.endDate}</p>
            <p class="text-xs">{experience.location}</p>
        </div>
    </div>
    <ul class="list-disc list-inside space-y-1 text-sm text-jet/80">
        {experience.responsibilities.map((responsibility: string) => (
            <li class="leading-relaxed">{responsibility}</li>
        ))}
    </ul>
</div>
