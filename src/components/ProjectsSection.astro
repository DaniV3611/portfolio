---
import { projects } from "../data/projects";
import { Rocket, Calendar, ExternalLink, Globe, Cpu, Building2 } from "@lucide/astro";

const featured = projects.filter(p => p.featured);
const regular = projects.filter(p => !p.featured);
---

<section id="projects" class="w-full py-20">
    <!-- Section Header -->
    <div class="flex items-center gap-4 mb-12">
        <div class="p-3 rounded-xl bg-gradient-to-br from-accent/10 to-secondary/10 border border-accent/20">
            <Rocket class="w-6 h-6 text-accent" />
        </div>
        <div>
            <h2 class="text-3xl font-bold text-text-primary">Projects & Ventures</h2>
            <p class="text-text-secondary mt-1">Things I've built and led</p>
        </div>
    </div>

    <!-- Featured Project -->
    {featured.map((project) => (
        <div class="group relative p-6 md:p-8 rounded-2xl glass-card overflow-hidden transition-all duration-500 hover:shadow-2xl hover:shadow-accent/10 mb-6">
            <!-- Top accent line -->
            <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/60 to-transparent"></div>
            <!-- Hover gradient fill -->
            <div class="absolute inset-0 bg-gradient-to-br from-accent/6 via-transparent to-secondary/4 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

            <div class="relative">
                <!-- Status row -->
                <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
                    <div class="flex items-center gap-2.5">
                        {project.url && (
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-success/10 border border-success/20 text-success text-xs font-semibold tracking-wide">
                                <span class="relative flex h-1.5 w-1.5">
                                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
                                    <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-success"></span>
                                </span>
                                LIVE
                            </span>
                        )}
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-accent/10 border border-accent/20 text-accent text-xs font-medium">
                            ★ Featured Project
                        </span>
                    </div>
                    <span class="flex items-center gap-2 text-sm text-text-muted">
                        <Calendar class="w-3.5 h-3.5" />
                        {project.startDate} – {project.endDate}
                    </span>
                </div>

                <!-- Content grid -->
                <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 lg:gap-8">
                    <!-- Left: Title, role, description (3/5) -->
                    <div class="lg:col-span-3 space-y-4">
                        <div>
                            <h3 class="text-2xl md:text-3xl font-bold text-text-primary group-hover:text-accent transition-colors duration-300">
                                {project.title}
                            </h3>
                            <p class="text-base font-medium text-secondary mt-1">{project.role}</p>
                        </div>
                        <ul class="space-y-3">
                            {project.description.map((item: string) => (
                                <li class="flex items-start gap-3 text-text-secondary text-sm leading-relaxed">
                                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-accent/60 flex-shrink-0"></span>
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>

                    <!-- Right: Tech stack + CTA (2/5) -->
                    <div class="lg:col-span-2 flex flex-col gap-5">
                        <div>
                            <p class="text-xs text-text-muted uppercase tracking-widest mb-3">Tech Stack</p>
                            <div class="flex flex-wrap gap-2">
                                {project.tech.map((t: string) => (
                                    <span class="px-2.5 py-1 text-xs bg-surface-elevated border border-border rounded-lg text-text-secondary hover:border-accent/50 hover:text-accent transition-all duration-200 cursor-default">
                                        {t}
                                    </span>
                                ))}
                            </div>
                        </div>
                        {project.url && (
                            <a
                                href={project.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 self-start px-5 py-2.5 bg-accent/10 hover:bg-accent/20 border border-accent/30 hover:border-accent/70 text-accent font-medium text-sm rounded-xl transition-all duration-200 group/btn"
                            >
                                <Globe class="w-4 h-4" />
                                View Project
                                <ExternalLink class="w-3.5 h-3.5 opacity-60 group-hover/btn:opacity-100 transition-opacity" />
                            </a>
                        )}
                    </div>
                </div>
            </div>
        </div>
    ))}

    <!-- Regular Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <!-- Jurisprudencia AI — violet/purple (AI feel) -->
        {regular[0] && (
            <div class="group relative p-6 rounded-2xl glass-card transition-all duration-300 hover:shadow-xl hover:shadow-violet-500/8 overflow-hidden">
                <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-violet-500/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="absolute inset-0 bg-gradient-to-br from-violet-500/4 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>

                <div class="relative">
                    <div class="flex items-center justify-between mb-4">
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-violet-500/10 border border-violet-500/20 text-violet-400 text-xs font-medium">
                            <Cpu class="w-3 h-3" />
                            AI / RAG
                        </span>
                        <span class="flex items-center gap-1.5 text-xs text-text-muted">
                            <Calendar class="w-3 h-3" />
                            {regular[0].startDate} – {regular[0].endDate}
                        </span>
                    </div>

                    <h3 class="text-xl font-semibold text-text-primary group-hover:text-violet-400 transition-colors duration-300 mb-1">
                        {regular[0].title}
                    </h3>
                    <p class="text-sm font-medium text-text-secondary mb-4">{regular[0].role}</p>

                    <ul class="space-y-2 mb-5">
                        {regular[0].description.map((item: string) => (
                            <li class="flex items-start gap-3 text-text-secondary text-sm">
                                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-violet-500/60 flex-shrink-0"></span>
                                <span class="leading-relaxed">{item}</span>
                            </li>
                        ))}
                    </ul>

                    <div class="flex flex-wrap gap-1.5 pt-4 border-t border-border">
                        {regular[0].tech.map((t: string) => (
                            <span class="px-2 py-1 text-xs bg-surface-elevated border border-border rounded-md text-text-muted hover:border-violet-500/40 hover:text-violet-400 transition-all duration-200 cursor-default">
                                {t}
                            </span>
                        ))}
                    </div>
                </div>
            </div>
        )}

        <!-- Tech Craft Solutions — amber/secondary (leadership feel) -->
        {regular[1] && (
            <div class="group relative p-6 rounded-2xl glass-card transition-all duration-300 hover:shadow-xl hover:shadow-secondary/8 overflow-hidden">
                <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-secondary/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="absolute inset-0 bg-gradient-to-br from-secondary/4 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>

                <div class="relative">
                    <div class="flex items-center justify-between mb-4">
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-secondary/10 border border-secondary/20 text-secondary text-xs font-medium">
                            <Building2 class="w-3 h-3" />
                            Startup
                        </span>
                        <span class="flex items-center gap-1.5 text-xs text-text-muted">
                            <Calendar class="w-3 h-3" />
                            {regular[1].startDate} – {regular[1].endDate}
                        </span>
                    </div>

                    <h3 class="text-xl font-semibold text-text-primary group-hover:text-secondary transition-colors duration-300 mb-1">
                        {regular[1].title}
                    </h3>
                    <p class="text-sm font-medium text-text-secondary mb-4">{regular[1].role}</p>

                    <ul class="space-y-2 mb-5">
                        {regular[1].description.map((item: string) => (
                            <li class="flex items-start gap-3 text-text-secondary text-sm">
                                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-secondary/60 flex-shrink-0"></span>
                                <span class="leading-relaxed">{item}</span>
                            </li>
                        ))}
                    </ul>

                    <div class="flex flex-wrap gap-1.5 pt-4 border-t border-border">
                        {regular[1].tech.map((t: string) => (
                            <span class="px-2 py-1 text-xs bg-surface-elevated border border-border rounded-md text-text-muted hover:border-secondary/40 hover:text-secondary transition-all duration-200 cursor-default">
                                {t}
                            </span>
                        ))}
                    </div>
                </div>
            </div>
        )}
    </div>
</section>
