---
import { projects } from "../data/projects";
import { Rocket, Calendar, ExternalLink, Globe, Cpu, Building2, FlaskConical } from "@lucide/astro";

const featured = projects.filter(p => p.featured);
const regular = projects.filter(p => !p.featured);

type CardStyle = {
    badge: string;
    dot: string;
    shadow: string;
    line: string;
    glow: string;
    hover: string;
    tagHover: string;
    icon: any;
    label: string;
};

const cardStyles: CardStyle[] = [
    {
        badge: "bg-violet-500/10 border-violet-500/20 text-violet-400",
        dot: "bg-violet-500/60",
        shadow: "hover:shadow-violet-500/8",
        line: "via-violet-500/40",
        glow: "from-violet-500/4",
        hover: "group-hover:text-violet-400",
        tagHover: "hover:border-violet-500/40 hover:text-violet-400",
        icon: Cpu,
        label: "AI / RAG",
    },
    {
        badge: "bg-secondary/10 border-secondary/20 text-secondary",
        dot: "bg-secondary/60",
        shadow: "hover:shadow-secondary/8",
        line: "via-secondary/40",
        glow: "from-secondary/4",
        hover: "group-hover:text-secondary",
        tagHover: "hover:border-secondary/40 hover:text-secondary",
        icon: Building2,
        label: "Startup",
    },
    {
        badge: "bg-success/10 border-success/20 text-success",
        dot: "bg-success/60",
        shadow: "hover:shadow-success/8",
        line: "via-success/40",
        glow: "from-success/4",
        hover: "group-hover:text-success",
        tagHover: "hover:border-success/40 hover:text-success",
        icon: FlaskConical,
        label: "Research",
    },
];
---

<section id="projects" class="w-full py-20">
    <!-- Section Header -->
    <div class="flex items-center gap-4 mb-12">
        <div class="p-3 rounded-xl bg-gradient-to-br from-accent/10 to-secondary/10 border border-accent/20">
            <Rocket class="w-6 h-6 text-accent" />
        </div>
        <div>
            <h2 class="text-3xl font-bold text-text-primary">Projects & Ventures</h2>
            <p class="text-text-secondary mt-1">Things I've built and led</p>
        </div>
    </div>

    <!-- Featured Project -->
    {featured.map((project) => (
        <div class="group relative p-6 md:p-8 rounded-2xl glass-card overflow-hidden transition-all duration-500 hover:shadow-2xl hover:shadow-accent/10 mb-6">
            <!-- Top accent line -->
            <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/60 to-transparent"></div>
            <!-- Hover gradient fill -->
            <div class="absolute inset-0 bg-gradient-to-br from-accent/6 via-transparent to-secondary/4 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>

            <div class="relative">
                <!-- Status row -->
                <div class="flex flex-wrap items-center justify-between gap-3 mb-6">
                    <div class="flex items-center gap-2.5">
                        {project.url && (
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-success/10 border border-success/20 text-success text-xs font-semibold tracking-wide">
                                <span class="relative flex h-1.5 w-1.5">
                                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
                                    <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-success"></span>
                                </span>
                                LIVE
                            </span>
                        )}
                        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-accent/10 border border-accent/20 text-accent text-xs font-medium">
                            ★ Featured Project
                        </span>
                    </div>
                    <span class="flex items-center gap-2 text-sm text-text-muted">
                        <Calendar class="w-3.5 h-3.5" />
                        {project.startDate} – {project.endDate}
                    </span>
                </div>

                <!-- Content grid -->
                <div class="grid grid-cols-1 lg:grid-cols-5 gap-6 lg:gap-8">
                    <!-- Left: Title, role, description (3/5) -->
                    <div class="lg:col-span-3 space-y-4">
                        <div>
                            <h3 class="text-2xl md:text-3xl font-bold text-text-primary group-hover:text-accent transition-colors duration-300">
                                {project.title}
                            </h3>
                            <p class="text-base font-medium text-secondary mt-1">{project.role}</p>
                        </div>
                        <ul class="space-y-3">
                            {project.description.map((item: string) => (
                                <li class="flex items-start gap-3 text-text-secondary text-sm leading-relaxed">
                                    <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-accent/60 flex-shrink-0"></span>
                                    {item}
                                </li>
                            ))}
                        </ul>
                    </div>

                    <!-- Right: Tech stack + CTA (2/5) -->
                    <div class="lg:col-span-2 flex flex-col gap-5">
                        <div>
                            <p class="text-xs text-text-muted uppercase tracking-widest mb-3">Tech Stack</p>
                            <div class="flex flex-wrap gap-2">
                                {project.tech.map((t: string) => (
                                    <span class="px-2.5 py-1 text-xs bg-surface-elevated border border-border rounded-lg text-text-secondary hover:border-accent/50 hover:text-accent transition-all duration-200 cursor-default">
                                        {t}
                                    </span>
                                ))}
                            </div>
                        </div>
                        {project.url && (
                            <a
                                href={project.url}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="inline-flex items-center gap-2 self-start px-5 py-2.5 bg-accent/10 hover:bg-accent/20 border border-accent/30 hover:border-accent/70 text-accent font-medium text-sm rounded-xl transition-all duration-200 group/btn"
                            >
                                <Globe class="w-4 h-4" />
                                View Project
                                <ExternalLink class="w-3.5 h-3.5 opacity-60 group-hover/btn:opacity-100 transition-opacity" />
                            </a>
                        )}
                    </div>
                </div>
            </div>
        </div>
    ))}

    <!-- Regular Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {regular.map((project, index) => {
            const style = cardStyles[index % cardStyles.length];
            const IconComponent = style.icon;
            return (
                <div class={`group relative p-6 rounded-2xl glass-card transition-all duration-300 hover:shadow-xl ${style.shadow} overflow-hidden`}>
                    <div class={`absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent ${style.line} to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300`}></div>
                    <div class={`absolute inset-0 bg-gradient-to-br ${style.glow} to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none`}></div>

                    <div class="relative">
                        <div class="flex items-center justify-between mb-4">
                            <span class={`inline-flex items-center gap-1.5 px-3 py-1 rounded-full border text-xs font-medium ${style.badge}`}>
                                <IconComponent class="w-3 h-3" />
                                {style.label}
                            </span>
                            <span class="flex items-center gap-1.5 text-xs text-text-muted">
                                <Calendar class="w-3 h-3" />
                                {project.startDate} – {project.endDate}
                            </span>
                        </div>

                        <h3 class={`text-xl font-semibold text-text-primary ${style.hover} transition-colors duration-300 mb-1`}>
                            {project.title}
                        </h3>
                        <p class="text-sm font-medium text-text-secondary mb-4">{project.role}</p>

                        <ul class="space-y-2 mb-5">
                            {project.description.map((item: string) => (
                                <li class="flex items-start gap-3 text-text-secondary text-sm">
                                    <span class={`mt-1.5 w-1.5 h-1.5 rounded-full ${style.dot} flex-shrink-0`}></span>
                                    <span class="leading-relaxed">{item}</span>
                                </li>
                            ))}
                        </ul>

                        {project.tech.length > 0 && (
                            <div class="flex flex-wrap gap-1.5 pt-4 border-t border-border">
                                {project.tech.map((t: string) => (
                                    <span class={`px-2 py-1 text-xs bg-surface-elevated border border-border rounded-md text-text-muted ${style.tagHover} transition-all duration-200 cursor-default`}>
                                        {t}
                                    </span>
                                ))}
                            </div>
                        )}
                    </div>
                </div>
            );
        })}
    </div>
</section>
