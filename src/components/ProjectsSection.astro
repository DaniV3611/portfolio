---
import { projects } from "../data/projects";
---

<section id="projects" class="w-full md:w-3xl lg:w-4xl pt-20">
    <h2 class="text-2xl font-bold text-jet/80 mb-6">Projects & Leadership</h2>
    <div class="flex flex-col gap-4">
        {projects.map((project) => (
            <div class="flex flex-col gap-3 p-6 rounded-lg border border-jet/10 hover:border-munsell/30 hover:shadow-lg transition-all duration-300 bg-ivory/50">
                <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-2">
                    <div class="flex-1">
                        <h3 class="text-lg font-semibold text-jet">{project.role}</h3>
                        <p class="text-md font-bold text-munsell">{project.title}</p>
                    </div>
                    <div class="text-sm text-jet/60 md:text-right">
                        <p>{project.startDate} - {project.endDate}</p>
                    </div>
                </div>
                <ul class="list-disc list-inside space-y-1 text-sm text-jet/80">
                    {project.description.map((item: string) => (
                        <li class="leading-relaxed">{item}</li>
                    ))}
                </ul>
            </div>
        ))}
    </div>
</section>
