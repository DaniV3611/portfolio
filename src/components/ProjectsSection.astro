---
import { projects } from "../data/projects";
import { Rocket, Calendar, ArrowUpRight } from "@lucide/astro";
---

<section id="projects" class="w-full py-20">
    <!-- Section Header -->
    <div class="flex items-center gap-4 mb-12">
        <div class="p-3 rounded-xl bg-gradient-to-br from-accent/10 to-secondary/10 border border-accent/20">
            <Rocket class="w-6 h-6 text-accent" />
        </div>
        <div>
            <h2 class="text-3xl font-bold text-text-primary">Projects & Leadership</h2>
            <p class="text-text-secondary mt-1">Initiatives and ventures</p>
        </div>
    </div>

    <!-- Projects Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {projects.map((project, index) => (
            <div class="group relative p-6 rounded-2xl bg-surface border border-border hover:border-accent/30 transition-all duration-300 hover:shadow-lg hover:shadow-accent/5 overflow-hidden">
                <!-- Gradient accent on hover -->
                <div class="absolute inset-0 bg-gradient-to-br from-accent/5 to-secondary/5 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                
                <div class="relative">
                    <!-- Badge -->
                    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 text-accent text-xs font-medium mb-4">
                        <Calendar class="w-3 h-3" />
                        {project.startDate} - {project.endDate}
                    </div>

                    <!-- Title & Role -->
                    <h3 class="text-xl font-semibold text-text-primary  transition-colors duration-300 mb-1">
                        {project.title}
                    </h3>
                    <p class="text-sm font-medium text-secondary mb-4">{project.role}</p>

                    <!-- Description -->
                    <ul class="space-y-2">
                        {project.description.map((item: string) => (
                            <li class="flex items-start gap-3 text-text-secondary text-sm">
                                <span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-accent/60 flex-shrink-0"></span>
                                <span class="leading-relaxed">{item}</span>
                            </li>
                        ))}
                    </ul>
                </div>
            </div>
        ))}
    </div>
</section>
