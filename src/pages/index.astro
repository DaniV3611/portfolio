---
import Layout from '../layouts/Layout.astro';
import { Mail } from '@lucide/astro';
---

<Layout>
	<section id="home" class="flex flex-col justify-center w-full md:w-3xl lg:w-4xl min-h-dvh gap-8">
		<h3 class="">Hello, my name is</h3>
		<h1 class="text-3xl md:text-7xl font-bold -mt-6 drop-shadow-md">Daniel Velasco</h1>
		<p class="text-md">I'm a <strong>Full Stack Developer</strong> at Bogotá, Colombia.</p>
		<p class="text-sm -mt-6">Passionate web development student with strong teamwork, communication, and creative problem-solving skills.<br> Eager to take on challenging projects that foster learning, growth, and innovative solutions.
		</p>
		<a href="/#contact" class="w-52">
			<button class="bg-jet/5 border hover:bg-jet/15 border-jet font-bold px-4 py-2 rounded-md w-52 cursor-pointer shadow-md transition-all duration-300 flex flex-row gap-2 items-center">
				<Mail />
				Get in touch
			</button>
		</a>
	</section>
	<section id="experience" class="w-full md:w-3xl lg:w-4xl pt-20">
		<h2 class="text-2xl font-bold text-black/80">Experience</h2>
		<div class="flex flex-col gap-4 h-dvh">
			<div class="flex flex-col gap-2">
				<h3 class="text-lg font-bold text-black/80">Full Stack Developer</h3>
				<p class="text-sm text-black/80">2024 - Present</p>
			</div>
		</div>
	</section>
</Layout>
